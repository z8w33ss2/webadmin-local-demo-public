# ──────────────────────────────────────────────────────────────────────────────
# WebAdmin Local – Demo Pública
# Variables de entorno de ejemplo. Copiar a .env.local para desarrollo.
# NUNCA incluir valores reales en este archivo.
# ──────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="VetCare Centro Veterinario"
NEXT_PUBLIC_APP_ENV=development

# WhatsApp (número ficticio para demo)
NEXT_PUBLIC_WHATSAPP_NUMBER=5215512345678

# Google Analytics (dejar vacío en demo)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ──────────────────────────────────────────────────────────────────────────────
# NOTA: Este proyecto es una DEMO. No se usan bases de datos ni APIs reales.
# Para integración con Supabase, agregar las siguientes variables:
# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
